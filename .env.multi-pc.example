# Copie este arquivo para .env.multi-pc e ajuste os endereços.
# Cada computador deve ter um NODE_ID diferente e o mesmo AUTH_SECRET.

NODE_ID=node-a
NODE_PORT=8000
PEERS=http://192.168.1.11:8000,http://192.168.1.12:8000

# Use uma sequência longa e idêntica nos três computadores.
AUTH_SECRET=troque-esta-chave-compartilhada
AUTH_SESSION_SECONDS=28800
POW_DIFFICULTY=3
AUTO_MINE=true

# Necessário apenas no computador que também executará o frontend.
NODE_URLS=http://192.168.1.10:8000,http://192.168.1.11:8000,http://192.168.1.12:8000
FRONTEND_PORT=5173
